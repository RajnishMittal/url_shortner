<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="wrap">
        <h1>URL shortener</h1>
        <p class="subtitle">Paste a long URL and get a short one instantly</p>
        <div class="card">
            <form action="/url" method="post" class="form-row">
                <input type="text" name="url" placeholder="https://example.com/long-url-here" />
                <button type="submit">Shorten</button>
            </form>
            <% if (locals.error) { %>
                    <div class="error"><%= error %></div>
                <% } %>
            <% if (locals.id) { %>
                <div class="result">
                    Short URL &rarr; <a target="_blank" href="/url/<%= id %>">http://localhost:8001/url/<%= id %></a>
                </div>
            <% } %>
        </div>

        <p>Logged in as: <%= locals.user ? user.email : "unknown" %></p>

        <% if (locals.urls && urls.length > 0) { %>
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Short ID</th>
                    <th>Original URL</th>
                    <th>Short URL</th>
                    <th>Clicks</th>
                </tr>
            </thead>
            <tbody>
                <% urls.forEach((url, index) => { %>
                <tr>
                    <td class="sno"><%= index + 1 %></td>
                    <td><code><%= url.shortId %></code></td>
                    <td class="muted"><%= url.redirectURL %></td>
                    <td><a target="_blank" class="short-link" href="/url/<%= url.shortId %>">http://localhost:8001/url/<%= url.shortId %></a></td>
                    <td><span class="badge"><%= url.visitHistory.length %></span></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</body>
</html>